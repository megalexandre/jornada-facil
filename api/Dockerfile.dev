# Imagem de DESENVOLVIMENTO da API Rails (para o dev container / docker-compose).
#
# Diferente do Dockerfile de produção (Kamal): aqui NÃO copiamos código nem
# excluímos o grupo :development. O código entra por bind-mount e as gems ficam
# num volume (`bundle`), então `bundle install` roda em runtime, não no build.
#
# RUBY_VERSION deve casar com api/.ruby-version.
ARG RUBY_VERSION=3.4.10
FROM docker.io/library/ruby:$RUBY_VERSION-slim

# Libs de build/runtime: pg + activerecord-postgis-adapter (libpq-dev),
# active_storage/image_processing (libvips), psych (libyaml-dev), bootsnap etc.
# unzip/xz-utils/ca-certificates são para o SDK do Flutter (abaixo).
#
# postgresql-client vem do repo oficial PGDG pinado em 16 (não do Debian trixie,
# que já empacota a 17): db/structure.sql é gerado com pg_dump e recarregado com
# psql — cliente e servidor (postgis/postgis:16-3.4, ver docker-compose.yml)
# precisam bater a major version, senão o dump sai com sintaxe que o servidor 16
# não reconhece (ex.: `SET transaction_timeout`, GUC novo no Postgres 17).
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y curl ca-certificates gnupg && \
    install -d /usr/share/postgresql-common/pgdg && \
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc && \
    echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] https://apt.postgresql.org/pub/repos/apt trixie-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
    apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git \
      libpq-dev postgresql-client-16 \
      libvips libyaml-dev pkg-config \
      unzip xz-utils && \
    rm -rf /var/lib/apt/lists/*

ENV BUNDLE_PATH=/usr/local/bundle \
    LANG=C.UTF-8

# SDK do Flutter: o devcontainer (.devcontainer/devcontainer.json) anexa o VS Code
# só no serviço `api` — então é AQUI, e não na imagem do serviço `web`, que a
# extensão Dart/Flutter precisa achar o SDK. Mesma receita do app/Dockerfile.dev:
# clona o canal stable ao vivo, porque a mirror ghcr.io/cirruslabs/flutter trava
# numa versão de Dart abaixo do `sdk: ^3.12.2` do pubspec.
ARG FLUTTER_CHANNEL=stable
RUN git clone --depth 1 -b "$FLUTTER_CHANNEL" https://github.com/flutter/flutter.git /opt/flutter && \
    git config --global --add safe.directory /opt/flutter
ENV PATH="/opt/flutter/bin:/opt/flutter/bin/cache/dart-sdk/bin:$PATH"

# O `ENV PATH` acima não basta: o Dev Containers do VS Code sonda o ambiente
# com um shell de LOGIN (userEnvProbe padrão = loginInteractiveShell) para
# descobrir o PATH usado ao lançar as extensões (Ruby LSP, Dart/Flutter). E o
# /etc/profile desta imagem (Debian) SOBRESCREVE o PATH para root com uma lista
# fixa antes de rodar /etc/profile.d/*.sh — apagando o /opt/flutter daqui. Um
# script em profile.d roda depois desse reset e devolve o Flutter ao PATH
# também em shells de login.
RUN echo 'export PATH="/opt/flutter/bin:/opt/flutter/bin/cache/dart-sdk/bin:$PATH"' > /etc/profile.d/flutter-path.sh

RUN flutter config --no-analytics && \
    flutter config --enable-web && \
    flutter precache --web && \
    flutter --version

# O compose monta a raiz do monorepo aqui; o working_dir efetivo é a subpasta api/.
WORKDIR /workspaces/jornada/api

EXPOSE 3000

# O comando real (bundle install + db:prepare + rails server) vem do compose,
# para manter a imagem genérica.
CMD ["bash"]
