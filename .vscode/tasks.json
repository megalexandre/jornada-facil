{
  // Dois comandos explícitos pra subir a stack no devcontainer, cada um num
  // terminal próprio (Terminal → Run Task, ou Ctrl+Shift+P → "Run Task"):
  //   • "Rails: server" — a API em localhost:3000.
  //   • "Flutter: web"  — o app em localhost:8080 (r = hot reload, R = restart).
  // O banco (db) sobe sozinho e o container da api já roda migrate+seed; aqui só
  // se inicia o que o dev controla. Pro Flutter com debugger/DevTools, use o F5
  // ("Flutter Web (dev)" em launch.json) em vez desta task.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rails: server",
      "type": "shell",
      "command": "bin/rails server -b 0.0.0.0 -p 3000",
      "options": { "cwd": "${workspaceFolder}/api" },
      "presentation": { "group": "stack", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Flutter: web",
      "type": "shell",
      "command": "flutter run -d web-server --web-port 8080 --dart-define-from-file=config/dev.json",
      "options": { "cwd": "${workspaceFolder}/app" },
      "presentation": { "group": "stack", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
