# Imagem de DESENVOLVIMENTO do app Flutter (serve a versão web ao vivo).
#
# Por que não usar ghcr.io/cirruslabs/flutter:stable? A mirror do cirruslabs está
# travada em Flutter 3.44.0 / Dart 3.12.0, abaixo do `sdk: ^3.12.2` do pubspec.
# Aqui clonamos o canal STABLE ao vivo — a MESMA fonte do CI
# (subosito/flutter-action channel: stable) — que hoje entrega Dart >= 3.12.2.
FROM debian:bookworm-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      git curl unzip xz-utils ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ARG FLUTTER_CHANNEL=stable
RUN git clone --depth 1 -b "$FLUTTER_CHANNEL" https://github.com/flutter/flutter.git /opt/flutter
ENV PATH="/opt/flutter/bin:/opt/flutter/bin/cache/dart-sdk/bin:$PATH"

# safe.directory: o SDK pertence ao root, mas o git roda em contexto montado.
# precache --web baixa o toolchain web já no build (primeiro `run` fica rápido).
RUN git config --global --add safe.directory /opt/flutter && \
    flutter config --no-analytics && \
    flutter config --enable-web && \
    flutter precache --web && \
    flutter --version

WORKDIR /app
EXPOSE 8080
CMD ["bash"]
