# Host do Postgres visto de dentro da rede do compose (nome do serviço)
DATABASE_HOST=db

# Porta do Postgres. Mudar aqui altera só o lado publicado no host
# (localhost:<porta>); dentro da rede o Postgres continua escutando em 5432
DATABASE_PORT=5432

# Usuário do banco (também vira o POSTGRES_USER do container do Postgres)
DATABASE_USER=postgres

# Senha do banco (o nome da variável vem do api/config/database.yml)
API_DATABASE_PASSWORD=postgres

# Nome do banco de desenvolvimento
DATABASE_NAME=api_development

# Ambiente do Rails dentro do container
RAILS_ENV=development

# Porta do Puma (interna e publicada no host com o mesmo número)
RAILS_PORT=3000

# Flutter web (serviço `web`)

# Porta do dev server do Flutter web (interna e publicada no host)
WEB_PORT=8080
WEB_API_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Suíte BDD (serviço `tests` — Cucumber, profile `bdd`)
# ----------------------------------------------------------------------------

API_BASE_URL=http://api:3000
API_HOST_HEADER=localhost
