{
  "name": "jornada",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "api",
  "workspaceFolder": "/workspaces/jornada",

  "runServices": ["db", "api"],

  "forwardPorts": [3000, 8080, 5432],
  "portsAttributes": {
    "3000": { "label": "API Rails" },
    "8080": { "label": "Flutter Web" },
    "5432": { "label": "Postgres" }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  "remoteEnv": {
    "CLAUDE_CONFIG_DIR": "/root/.claude"
  },

  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "KoichiSasada.vscode-rdbg",
        "Dart-Code.flutter",
        "ms-ossdata.vscode-pgsql",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "CucumberOpen.cucumber-official"
      ],
      "settings": {
        "cucumber.features": ["features/**/*.feature"],
        "cucumber.glue": ["features/step_definitions/**/*.rb"],
        "rubyLsp.bundleGemfile": "api/Gemfile",
        "dart.flutterSdkPath": "/opt/flutter"
      }
    }
  }
}
