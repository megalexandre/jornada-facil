{
  "name": "jornada",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "api",
  "workspaceFolder": "/workspaces/jornada",

  "runServices": ["db", "api", "web"],

  "forwardPorts": [3000, 8080, 5432],
  "portsAttributes": {
    "3000": { "label": "API Rails" },
    "8080": { "label": "Flutter Web" },
    "5432": { "label": "Postgres" }
  },

  "postCreateCommand": "cd /workspaces/jornada/api && bundle install && cd /workspaces/jornada && bundle install && cd /workspaces/jornada/app && flutter pub get",

  "features": {
    // Node é pré-requisito do claude-code: no Debian trixie do ruby:slim o
    // instalador automático da feature falha (nodejs do Debian vem sem npm).
    // A feature do claude-code declara installsAfter node, então a ordem é garantida.
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "KoichiSasada.vscode-rdbg",
        "Dart-Code.flutter",
        "ms-ossdata.vscode-pgsql",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "CucumberOpen.cucumber-official"
      ],
      "settings": {
        "cucumber.features": ["features/**/*.feature"],
        "cucumber.glue": ["features/step_definitions/**/*.rb"]
      }
    }
  }
}
